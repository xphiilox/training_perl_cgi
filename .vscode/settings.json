{
  "files.associations": {
    "*.cgi": "perl",
    "*.pl": "perl",
    "*.pm": "perl",
    "*.t": "perl"
  },
  "[perl]": {
    "editor.defaultFormatter": "richterger.perl"
  },
  "perl.perlCmd": "/usr/local/bin/perl",
  "perl.perlInc": [
    "${workspaceFolder}/lib"
  ],
  "perl.debugAdapterPort": 15603,
  "perl.debugAdapterPortRange": 1000,
  "perl.fileFilter": [
    "*.cgi",
    "*.pl",
    "*.pm",
    "*.t"
  ],
  "editor.glyphMargin": true,
  "debug.allowBreakpointsEverywhere": true
}
